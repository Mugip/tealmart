// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For email/password auth
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts  Account[]
  sessions  Session[]
  orders    Order[]
  reviews   Review[]
  addresses SavedAddress[]
  wishlist  WishlistItem[]

  @@index([email])
}

// ============================================
// PRODUCT CATALOG
// ============================================

model Product {
  id             String         @id @default(cuid())
  externalId     String?        @unique
  title          String
  description    String         @db.Text
  price          Float
  costPrice      Float?
  compareAtPrice Float?
  images         String[]
  category       String
  tags           String[]       @default([])
  rating         Float?
  reviewCount    Int            @default(0)
  source         String?
  isActive       Boolean        @default(true)
  isFeatured     Boolean        @default(false)
  stock          Int            @default(0)
  views          Int            @default(0)
  conversions    Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  variants       Json?
  
  // Relations
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]

  @@index([category])
  @@index([isActive, isFeatured])
  @@index([createdAt])
  @@index([externalId])
  @@index([source])
}

// ============================================
// ORDER MANAGEMENT
// ============================================

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  email           String
  status          OrderStatus @default(PENDING)
  total           Float
  subtotal        Float
  tax             Float       @default(0)
  shipping        Float       @default(0)
  shippingName    String
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZip     String
  shippingCountry String
  shippingPhone   String?
  paymentMethod   String
  paymentId       String?
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  user  User?       @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([orderNumber])
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  
  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ============================================
// NEXTAUTH MODELS
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// PRODUCT REVIEWS
// ============================================

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int      // 1-5
  title     String?
  comment   String?
  images    String[] // Array of image URLs
  verified  Boolean  @default(false) // Verified purchase
  helpful   Int      @default(0) // Helpful votes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
}

// ============================================
// SAVED ADDRESSES
// ============================================

model SavedAddress {
  id        String  @id @default(cuid())
  userId    String
  name      String
  address   String
  city      String
  state     String
  zip       String
  country   String
  phone     String?
  isDefault Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// WISHLIST
// ============================================

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

// ============================================
// DISCOUNT CODES
// ============================================

model DiscountCode {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String    // PERCENTAGE, FIXED, FREE_SHIPPING
  value       Float     // Percentage or fixed amount
  minPurchase Float?    // Minimum purchase amount
  maxUses     Int?      // Max number of uses
  usedCount   Int       @default(0)
  validFrom   DateTime  @default(now())
  validUntil  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([code])
  @@index([isActive])
}

// ============================================
// NEWSLETTER SUBSCRIBERS
// ============================================

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  status    String   @default("ACTIVE") // ACTIVE, UNSUBSCRIBED
  source    String?  // Where they subscribed from
  createdAt DateTime @default(now())

  @@index([email])
  @@index([status])
}

// ============================================
// PRICING & RULES
// ============================================

model PricingRule {
  id        String   @id @default(cuid())
  category  String   @unique
  markup    Float    @default(1.3)
  minRating Float    @default(4.2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

// ============================================
// INGESTION & LOGGING
// ============================================

model IngestionLog {
  id              String   @id @default(cuid())
  source          String
  productsAdded   Int      @default(0)
  productsUpdated Int      @default(0)
  errors          String?  @db.Text
  status          String
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([source])
  @@index([status])
}

// ============================================
// ADMIN SETTINGS
// ============================================

model AdminSettings {
  id                       String   @id @default(cuid())
  storeName                String   @default("TealMart")
  storeEmail               String   @default("support@tealmart.com")
  storePhone               String?
  currency                 String   @default("USD")
  orderNotifications       Boolean  @default(true)
  lowStockAlerts           Boolean  @default(true)
  dailyReports             Boolean  @default(false)
  customerMessages         Boolean  @default(true)
  maintenanceMode          Boolean  @default(false)
  allowGuestCheckout       Boolean  @default(true)
  requireEmailVerification Boolean  @default(false)
  autoApproveReviews       Boolean  @default(false)
  updatedAt                DateTime @updatedAt
}

// ============================================
// CJ DROPSHIPPING TOKEN CACHE
// ============================================

model CJTokenCache {
  key       String   @id
  value     String   @db.Text
  expiresAt DateTime
  updatedAt DateTime @default(now()) @updatedAt

  @@index([expiresAt])
}

// ============================================
// ENUMS
// ============================================

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}
