// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@index([email])
}

// ============================================
// PRODUCT CATALOG
// ============================================

model Product {
  id             String      @id @default(cuid())
  externalId     String?     @unique
  title          String
  description    String      @db.Text
  price          Float
  costPrice      Float?
  compareAtPrice Float?
  images         String[]
  category       String
  tags           String[]    @default([])
  rating         Float?
  reviewCount    Int         @default(0)
  source         String?
  isActive       Boolean     @default(true)
  isFeatured     Boolean     @default(false)
  stock          Int         @default(0)
  views          Int         @default(0)
  conversions    Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  variants       Json?
  orderItems     OrderItem[]

  @@index([category])
  @@index([isActive, isFeatured])
  @@index([createdAt])
  @@index([externalId])
  @@index([source])
}

// ============================================
// ORDER MANAGEMENT
// ============================================

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  email           String
  status          OrderStatus @default(PENDING)
  total           Float
  subtotal        Float
  tax             Float       @default(0)
  shipping        Float       @default(0)
  shippingName    String
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZip     String
  shippingCountry String
  paymentMethod   String
  paymentId       String?
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User?       @relation(fields: [userId], references: [id])
  items           OrderItem[]

  @@index([orderNumber])
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ============================================
// PRICING & RULES
// ============================================

model PricingRule {
  id        String   @id @default(cuid())
  category  String   @unique
  markup    Float    @default(1.3)
  minRating Float    @default(4.2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

// ============================================
// INGESTION & LOGGING
// ============================================

model IngestionLog {
  id              String   @id @default(cuid())
  source          String
  productsAdded   Int      @default(0)
  productsUpdated Int      @default(0)
  errors          String?  @db.Text
  status          String
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([source])
  @@index([status])
}

// ============================================
// CJ DROPSHIPPING TOKEN CACHE
// ============================================

model CJTokenCache {
  key       String   @id
  value     String   @db.Text
  expiresAt DateTime
  updatedAt DateTime @default(now()) @updatedAt

  @@index([expiresAt])
}

// ============================================
// ENUMS
// ============================================

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}
