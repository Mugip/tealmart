// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  orders    Order[]
}

model Product {
  id              String   @id @default(cuid())
  externalId      String?  @unique // ID from source (eBay, AliExpress, etc.)
  title           String
  description     String   @db.Text
  price           Float
  costPrice       Float? // Original cost for margin calculation
  compareAtPrice  Float? // Original price for discount display
  images          String[] // Array of image URLs
  category        String
  tags            String[]
  rating          Float?
  reviewCount     Int      @default(0)
  source          String? // 'ebay', 'aliexpress', 'temu', 'mock'
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  stock           Int      @default(0)
  views           Int      @default(0)
  conversions     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  orderItems      OrderItem[]
  
  @@index([category])
  @@index([isActive, isFeatured])
  @@index([createdAt])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  email           String
  status          OrderStatus @default(PENDING)
  total           Float
  subtotal        Float
  tax             Float       @default(0)
  shipping        Float       @default(0)
  
  // Shipping details
  shippingName    String
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingZip     String
  shippingCountry String
  
  // Payment
  paymentMethod   String // 'stripe', 'paypal'
  paymentId       String?
  paidAt          DateTime?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  user            User?       @relation(fields: [userId], references: [id])
  items           OrderItem[]
  
  @@index([orderNumber])
  @@index([email])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float // Price at time of purchase
  
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])
  
  @@index([orderId])
  @@index([productId])
}

model PricingRule {
  id          String   @id @default(cuid())
  category    String   @unique
  markup      Float    @default(1.3) // 30% markup
  minRating   Float    @default(4.2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IngestionLog {
  id          String   @id @default(cuid())
  source      String
  productsAdded Int     @default(0)
  productsUpdated Int   @default(0)
  errors      String?  @db.Text
  status      String   // 'success', 'partial', 'failed'
  createdAt   DateTime @default(now())
  
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}
